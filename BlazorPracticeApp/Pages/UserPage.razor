@page "/user"
@using BlazorPracticeApp.ApiRequest.Models
@using Microsoft.AspNetCore.Components
@inject IJSRuntime JS
@inject NavigationManager navigation


<div class="user-shell">
    <div class="user-shell__header">
        <div class="user-shell__avatar">
            <span>@(string.IsNullOrEmpty(name) ? "U" : name[0].ToString().ToUpper())</span>
        </div>
        <div class="user-shell__info">
            <p class="user-shell__label">Профиль</p>
            <h3 class="user-shell__title">@name</h3>
        </div>
        <button class="btn-primary" type="button" @onclick="Logout">
            Выход
        </button>
    </div>
</div>

@code
{
    [Parameter]
    [SupplyParameterFromQuery]
    public string name { get; set; }
    
    public async Task Logout()
    {
        await JS.InvokeAsync<string>("sessionStorage.removeItem", "token");
        navigation.NavigateTo("/");
    }
}


