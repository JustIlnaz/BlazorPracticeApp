            }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .link {
        color: #2563eb;
