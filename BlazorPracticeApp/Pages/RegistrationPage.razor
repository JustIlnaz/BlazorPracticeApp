@page "/reg"
@using BlazorPracticeApp.ApiRequest
@using BlazorPracticeApp.ApiRequest.Models
@inject NavigationManager navigation


<div class="page-container">
    <div class="login-card">

        <h1 class="page-title" style="color: #4B5563">Регистрация</h1>

        <form class="login-form">

            <div class="form-group">
                <label style="color: #6B7280">Имя</label>
                <input @bind="user.Name" type="text" placeholder="Введите имя" />
            </div>
            
            <div class="form-group">
                <label style="color: #6B7280">О себе</label>
                <input @bind="user.Description" type="text" placeholder="Напишите о себе" />
            </div>
            
            <!-- Логин -->
            <div class="form-group">
                <label style="color: #6B7280">Email</label>
                <input @bind="user.Email" type="text" placeholder="Введите Email" />
            </div>

            <!-- Пароль -->
            <div class="form-group">
                <label style="color: #6B7280">Пароль</label>
                <input @bind="user.Password" type="password" placeholder="Введите пароль" />
            </div>
            
            <!-- Кнопка входа -->
            <button type="button" class="btn-primary"
                    @onclick="Registration">
                Зарегистрироваться
            </button>

            <!-- Регистрация -->
            <div class="register-block">
                <span style="color: #6B7280">Есть аккаунт?</span>
                <a href="/" class="link">Авторизоваться</a>
            </div>

          

        </form>

    </div>
</div>

@code {

    [Inject] private ApiRequest api { get; set; }
    public CreateUser user = new CreateUser();

    public async Task Registration()
    {
        if (string.IsNullOrWhiteSpace(user.Email) || string.IsNullOrWhiteSpace(user.Password) || string.IsNullOrWhiteSpace(user.Name)) return;
        var regdata = await api.RegistrationUser(user);
        if (regdata.status == true)
        {
            navigation.NavigateTo("/");
        }
        else
        {
            return;
        }
    }

}

<style>
    /* ===== Общий контейнер страницы ===== */
    .page-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
        display: flex;
        justify-content: center;
    }

    /* ===== Карточка авторизации ===== */
    .login-card {
        width: 100%;
        max-width: 420px;
        background-color: #ffffff;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    }

    /* ===== Заголовок ===== */
    .page-title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 25px;
        color: #222;
    }

    /* ===== Форма ===== */
    .login-form {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            margin-bottom: 6px;
            font-weight: 500;
            color: #333;
        }

        .form-group input {
            padding: 10px 12px;
            border: 1px solid #C7D2FE;
            border-radius: 8px;
            font-size: 14px;
        }

            .form-group input:focus {
                outline: none;
                border-color: #6366F1;
            }

    /* ===== Опции ===== */
    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* ===== Ссылки ===== */
    .link {
        color: #2563eb;
        text-decoration: none;
    }

        .link:hover {
            color: #4F46E5;
        }

    /* ===== Основная кнопка ===== */
    .btn-primary {
        padding: 12px;
        border: none;
        border-radius: 8px;
        background-color: #6366F1;
        color: white;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #4F46E5;
        }

        .btn-primary:disabled {
            background-color: #9ca3af;
            cursor: not-allowed;
        }

    /* ===== Регистрация ===== */
    .register-block {
        text-align: center;
        font-size: 14px;
    }

    /* ===== Разделитель ===== */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 10px 0;
        color: #888;
    }

        .divider::before,
        .divider::after {
            content: "";
            flex: 1;
            border-bottom: 1px solid #ddd;
        }

        .divider span {
            padding: 0 10px;
        }

    /* ===== Соцкнопки ===== */
    .social-login {
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .btn-social {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid #ccc;
        background-color: #f9fafb;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .btn-social:hover {
            background-color: #2563eb;
            color: white;
            border-color: #2563eb;
        }

</style>