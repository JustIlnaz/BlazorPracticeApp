        }

        .divider span {
            padding: 0 10px;
        }

    .social-login {
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .btn-social {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid #ccc;
        background-color: #f9fafb;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .btn-social:hover {
            background-color: #2563eb;
            color: white;
            border-color: #2563eb;
        }

</style>

