@page "/reg"
@using BlazorPracticeApp.ApiRequest
@using BlazorPracticeApp.ApiRequest.Models
@inject NavigationManager navigation


<div class="page-container">
    <div class="login-card">

        <h1 class="page-title" style="color: #4B5563">Регистрация</h1>

        <form class="login-form">

            <div class="form-group">
                <label style="color: #6B7280">Имя</label>
                <input @bind="user.Name" type="text" placeholder="Введите имя" />
            </div>

            <div class="form-group">
                <label style="color: #6B7280">О себе</label>
                <input @bind="user.Description" type="text" placeholder="Напишите о себе" />
            </div>
            
            <div class="form-group">
                <label style="color: #6B7280">Email</label>
                <input @bind="user.Email" type="text" placeholder="Введите Email" />
            </div>

            <div class="form-group">
                <label style="color: #6B7280">Пароль</label>
                <input @bind="user.Password" type="password" placeholder="Введите пароль" />
            </div>
            <button type="button" class="btn-primary"
                    @onclick="Registration">
                Зарегистрироваться
            </button>

            <div class="register-block">
                <span style="color: #6B7280">Есть аккаунт?</span>
                <a href="/" class="link">Авторизоваться</a>
            </div>

          

        </form>

    </div>
</div>

@code {

    [Inject] private ApiRequest Api { get; set; }
    public CreateUser user = new CreateUser();

    public async Task Registration()
    {
        if (string.IsNullOrWhiteSpace(user.Email) || string.IsNullOrWhiteSpace(user.Password) || string.IsNullOrWhiteSpace(user.Name)) return;
        var regdata = await Api.RegistrationUser(user);
        if (regdata.status == true)
        {
            navigation.NavigateTo("/");
        }
        else
        {
            return;
        }
    }

}

<style>
    .page-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
        display: flex;
        justify-content: center;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        background-color: #ffffff;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    }

    .page-title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 25px;
        color: #222;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            margin-bottom: 6px;
            font-weight: 500;
            color: #333;
        }

        .form-group input {
            padding: 10px 12px;
            border: 1px solid #C7D2FE;
            border-radius: 8px;
            font-size: 14px;
        }

            .form-group input:focus {
                outline: none;
